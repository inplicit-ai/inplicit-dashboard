# Inplicit dashboard (Next.js) — runtime config.
#
# API_URL is the backend URL the dashboard calls server-side (RSC fetches +
# `dapi/*` proxy). Local dev: http://localhost:8080
# Production: set in Vercel → Project → Settings → Environment Variables
# (e.g. https://inplicit-backend.fly.dev).

API_URL=http://localhost:8080

# Jam screen recording link for the feedback button.
# Create a recording link at https://jam.dev → share → "Recording Link".
# Leave empty to disable the button.
NEXT_PUBLIC_JAM_RECORDING_URL=
